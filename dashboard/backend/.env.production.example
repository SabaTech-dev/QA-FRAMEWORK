# QA-FRAMEWORK Backend — Production Environment Template
# Copy this file to .env.production and fill in real values.
#   cp .env.production.example .env.production
#
# IMPORTANT: .env.production is gitignored and MUST NOT be committed.
#
# Wired via env_file in docker-compose.coolify.yml (backend service).
#
# Generate the JWT secret:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(32))'

# ===========================================
# ENVIRONMENT
# ===========================================
ENVIRONMENT=production

# ===========================================
# DATABASE
# Format: postgresql+asyncpg://user:password@host:port/database
# Host is the postgres service/container name on the docker network.
# ===========================================
DATABASE_URL=postgresql+asyncpg://qa_user:CHANGE_ME_DB_PASSWORD@qa-beta-postgres:5432/qa_dashboard

# ===========================================
# REDIS
# Host is the redis service/container name on the docker network.
# ===========================================
REDIS_HOST=qa-beta-redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ===========================================
# JWT AUTHENTICATION
# NOTE: dashboard/backend/config.py reads JWT_SECRET_KEY (line 27), NOT SECRET_KEY.
# Keep both names set to the same value for compatibility.
# ===========================================
SECRET_KEY=CHANGE_ME_GENERATED_VIA_secrets_token_urlsafe_32
JWT_SECRET_KEY=CHANGE_ME_GENERATED_VIA_secrets_token_urlsafe_32

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO
